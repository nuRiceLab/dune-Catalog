# ---------------------------------------------------------------------------
# DUNE Catalog environment configuration template.
# Copy to `.env` and fill in real values. `.env` is gitignored.
# ---------------------------------------------------------------------------

# --- MetaCat backend -------------------------------------------------------
METACAT_SERVER_URL=https://your-metacat-server
METACAT_AUTH_SERVER_URL=https://your-metacat-auth-server

# --- Frontend -> backend API base ------------------------------------------
# Local dev: backend (uvicorn) port from run.py.
# Production: https://<host>/dunecatalog/api
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- CILogon OIDC client ---------------------------------------------------
# Register a Confidential client at https://cilogon.org/oauth2/register
# Scopes: openid email profile org.cilogon.userinfo
CILOGON_CLIENT_ID=cilogon:/client_id/xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CILOGON_CLIENT_SECRET=your-client-secret
CILOGON_DISCOVERY_URL=https://cilogon.org/.well-known/openid-configuration
CILOGON_SCOPES=openid email profile org.cilogon.userinfo

# Must exactly match a Callback URL registered with the CILogon client.
# Dev:  http://localhost:8080/auth/callback
# Prod: https://<host>/dunecatalog/api/auth/callback
CILOGON_REDIRECT_URI=http://localhost:8080/auth/callback

# Where the backend redirects the user after login (include the basePath).
# Dev:  http://localhost:3001/dunecatalog
# Prod: https://<host>/dunecatalog
FRONTEND_URL=http://localhost:3001/dunecatalog

# --- Session JWT -----------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me
TOKEN_EXPIRY_MINUTES=1440
ENVIRONMENT=development
